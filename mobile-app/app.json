{
  "expo": {
    "name": "DOOODHWALA",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "scheme": "dooodhwala",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.dooodhwala.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "requireFullScreen": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "DOOODHWALA uses your location to track deliveries and find milkmen near you.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "DOOODHWALA uses your location in the background to track live delivery progress.",
        "NSCameraUsageDescription": "DOOODHWALA uses your camera to upload your profile photo.",
        "NSPhotoLibraryUsageDescription": "DOOODHWALA accesses your photo library to let you choose a profile picture.",
        "NSPhotoLibraryAddUsageDescription": "DOOODHWALA saves images to your photo library.",
        "NSUserNotificationsUsageDescription": "DOOODHWALA sends you delivery updates and order alerts.",
        "UIBackgroundModes": [
          "location",
          "remote-notification"
        ]
      },
      "associatedDomains": [
        "applinks:dooodhwala.com"
      ]
    },
    "android": {
      "package": "com.dooodhwala.app",
      "versionCode": 9,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "dooodhwala.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "DOOODHWALA uses your location to track deliveries and find milkmen near you.",
          "locationAlwaysPermission": "DOOODHWALA uses your location in the background to track live delivery progress.",
          "locationWhenInUsePermission": "DOOODHWALA uses your location to track deliveries and find milkmen near you.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#2563EB",
          "sounds": []
        }
      ],
      "@rnmapbox/maps",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "DOOODHWALA accesses your photos to let you set a profile picture.",
          "cameraPermission": "DOOODHWALA uses your camera to take a profile photo."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9a8b04b4-d793-400b-b71e-b410d0afc2ff"
      },
      "privacyPolicyUrl": "https://dooodhwala.com/privacy-policy",
      "termsUrl": "https://dooodhwala.com/terms",
      "supportEmail": "support@dooodhwala.com"
    },
    "owner": "siddhant_20",
    "updates": {
      "enabled": false
    }
  }
}
