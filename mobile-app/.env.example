# Mapbox Access Token (public token for maps display)
# Get yours at https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token_here

# Mapbox Secret Download Token (for native SDK downloads during EAS build)
# Create a secret token at https://account.mapbox.com/access-tokens/
# with scope: Downloads:Read
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=your_mapbox_secret_download_token_here
