# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require

# Authentication
JWT_SECRET=your_production_secure_jwt_secret_key_here

# Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMS Gateway (Android Gateway App)
# The secret key that the Android Gateway app must send in headers to authenticate itself
GATEWAY_SECRET=complex_secret_key_match_with_android_app

# Mobile App & CORS
# The URL where your PWA will live or the scheme for the mobile app
MOBILE_APP_URL=https://dooodhwala.com
PORT=5001

# Payments (Razorpay / Stripe)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxx

# Node Environment
NODE_ENV=production
