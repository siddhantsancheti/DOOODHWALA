# DOOODHWALA — backend environment variables (example)
# Copy to .env for local dev, or set these in Render for production.
# NEVER commit real secrets. This file holds placeholders only.

# ── Core ───────────────────────────────────────────────
NODE_ENV=development
PORT=5001
# Postgres connection (Supabase). Use the POOLED connection (port 6543) in prod.
DATABASE_URL=postgresql://user:password@host:6543/postgres
# Long random string — the server refuses to boot without it.
JWT_SECRET=replace-with-a-long-random-secret

# ── Auth / Firebase ────────────────────────────────────
# Full service-account JSON (single line) for project dooodhwala-7dce6.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"dooodhwala-7dce6", "...":"..."}
FIREBASE_STORAGE_BUCKET=dooodhwala-7dce6.firebasestorage.app

# ── Payments: Razorpay ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
# Used to verify webhook signatures. Set the SAME value in the Razorpay
# dashboard webhook config. See docs/PAYMENTS.md.
RAZORPAY_WEBHOOK_SECRET=replace-with-a-strong-random-string

# ── Payments: Stripe (optional / international) ─────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Maps ───────────────────────────────────────────────
MAPBOX_SECRET_TOKEN=
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# ── Misc ───────────────────────────────────────────────
# Internal service-to-service auth for the gateway routes.
GATEWAY_SECRET=
# Phone number granted admin access.
ADMIN_PHONE=+91XXXXXXXXXX
# App-store review test account: this ONE phone accepts the fixed OTP below so a
# Google Play / App Store reviewer can sign in without receiving a real SMS.
# Leave BOTH blank in normal operation — the bypass is inert unless set.
# Enter the same number + OTP in Play Console → App content → App access.
REVIEW_TEST_PHONE=
REVIEW_TEST_OTP=123456
# Cloudinary (legacy media — only if used).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
